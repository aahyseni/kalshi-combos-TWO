# Copy this file to `.env` (gitignored) and fill in real values.
# Existing environment variables always take precedence over this file.
# Private keys stay in their own .pem files — reference them by path here.
# NEVER put real keys in THIS file — it is the committed template.

# --- Kalshi DEMO maker account (create at the demo site; key shown once) ---
KALSHI_API_KEY_ID=00000000-0000-0000-0000-000000000000
KALSHI_PRIVATE_KEY_PATH=C:\Users\you\.kalshi\demo-maker.pem

# --- Second demo account (requester side, Phase 2.5 ground-truth harness) ---
KALSHI_REQUESTER_API_KEY_ID=00000000-0000-0000-0000-000000000000
KALSHI_REQUESTER_PRIVATE_KEY_PATH=C:\Users\you\.kalshi\demo-requester.pem

# --- External odds (optional; enables the SportsGameOdds OddsSource) ---
SPORTSGAMEODDS_API_KEY=
